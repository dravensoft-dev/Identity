{
  "component": "Button",
  "slots": {
    "root": "inline-flex items-center justify-center gap-2 rounded-sm font-semibold transition-[background,transform,box-shadow] duration-[var(--dur-fast)] ease-[var(--ease-out)]"
  },
  "variants": {
    "variant": {
      "primary": { "root": "bg-primary text-primary-content border-[length:var(--bw)] border-primary hover:shadow-2" },
      "danger":  { "root": "bg-transparent border-[length:var(--bw)] border-error text-error hover:bg-[var(--danger-soft)]" }
    },
    "size": {
      "sm": { "root": "h-ctl-h-sm px-3 text-ctl-md" },
      "md": { "root": "h-ctl-h px-4.5 text-ctl" },
      "lg": { "root": "h-ctl-h-lg px-6.5 text-ctl" }
    }
  },
  "defaultVariants": { "variant": "primary", "size": "md" }
}
